{
  "name": "rankforge-workspace",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "rankforge-workspace",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/rankforge": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/cli": {
      "name": "rankforge",
      "version": "0.4.0",
      "license": "MIT",
      "bin": {
        "rankforge": "src/index.mjs"
      },
      "engines": {
        "node": ">=20"
      },
      "peerDependencies": {
        "playwright": ">=1.40.0"
      },
      "peerDependenciesMeta": {
        "playwright": {
          "optional": true
        }
      }
    }
  }
}
